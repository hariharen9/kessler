pkgname=kessler-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="🛰️ Intelligent CLI tool to find and safely clean build artifacts & caches"
arch=('x86_64' 'aarch64')
url="https://github.com/hariharen9/kessler"
license=('MIT')
provides=('kessler')
conflicts=('kessler')

source_x86_64=("${url}/releases/download/v${pkgver}/kessler_${pkgver}_linux_amd64.tar.gz")
source_aarch64=("${url}/releases/download/v${pkgver}/kessler_${pkgver}_linux_arm64.tar.gz")

# Update these after first release
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

package() {
    install -Dm755 kessler "${pkgdir}/usr/bin/kessler"
}
